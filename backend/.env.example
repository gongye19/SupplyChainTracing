DATABASE_URL=postgresql://postgres:123456@localhost:5433/supplychain
CORS_ORIGINS=http://localhost:3000

# Keep disabled until the server worker is deployed and tested.
INSIGHT_JOBS_ENABLED=false
DEFAULT_DATASET_VERSION=
INSIGHT_WORKER_TOKEN=replace-with-a-long-random-secret

# Lightweight chat is processed by the separate outbound server worker.
CHAT_JOBS_ENABLED=false
CHAT_WORKER_TOKEN=replace-with-a-different-long-random-secret
